{
  "description": "vhal-svc：VHAL 矩阵飞书 fetch → VehicleGenerateTool 生成 → 指定 json/proto 部署到 vehicleservice 仓库",
  "projects": {
    "n5x": {
      "description": "北汽 N50 系 VHAL（project_code N50）；飞书表 + 部署至 BAIC vehicleservice 的 n50 与 n51 两套目录",
      "input": { "dir": "input/n5x" },
      "feishu": {
        "spreadsheet": "https://t83dfrspj4.feishu.cn/sheets/PvBxsSOVshEyuztjCcAcvKacn6e?sheet=2a0314"
      },
      "vehicle_generate": {
        "script": "vehicle_generate_tool_QA.py",
        "matrix_file": "auto",
        "map_sheet": "releaseMap",
        "project_code": "N50"
      },
      "generate": {
        "output_dir": "output/n5x",
        "copy_result_dir": true
      },
      "deploy": {
        "repo": "~/BAIC_8775/n50_al_dev/qnx/vendor/autolink/hal/vehicleservice/",
        "branch": "al_dev",
        "files": [
          { "source": "vehicle_prop_config.json", "dest": "etc/n50" },
          { "source": "vehicle_prop_value.json", "dest": "etc/n50" },
          { "source": "autolink.alc.signal.pb.proto", "dest": "vehicleclient/proto/n50" },
          { "source": "vehicle_prop_config.json", "dest": "etc/n51" },
          { "source": "vehicle_prop_value.json", "dest": "etc/n51" },
          { "source": "autolink.alc.signal.pb.proto", "dest": "vehicleclient/proto/n51" }
        ]
      },
      "compile": { "cwd": "", "args": [] }
    },
