    /**
     * DOORSLDWARNREASON_RL_248
     *
     * Function Describe: 开门条件不满足原因
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x0: Not active
         0x1: 手动模式
         0x2: 车速超标或无效
         0x3: 中控锁锁止
         0x4: 儿童锁锁止
         0x5: 车窗互锁功能激活
         0x6: 充电口互锁功能激活
         0x7: 加油口锁功能激活
         0x8: 防夹条防夹事件
         0x9: 电流霍尔防夹事件
         0xA: 防玩保护激活
         0xB: 洗车模式
         0xC: 供电电压欠压or过压
         0xD: 未完成自学习
         0xE: 滑门状态为Ukwn
         0xF: 锁系统故障
         0x10: 驱动器故障
         0x11: 碰撞保护激活
     */
    DOORSLDWARNREASON_RL_248 = (
        0x13D8
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

