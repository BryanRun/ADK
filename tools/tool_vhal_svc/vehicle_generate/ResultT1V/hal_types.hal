package vendor.autolink.vehiclehal@2.0;

import android.hardware.automotive.vehicle@2.0;

enum VendorVehicleArea : int32_t {
    GLOBAL                         = 0x01000000,
    WINDOW                         = 0x03000000,
    MIRROR                         = 0x04000000,
    SEAT                           = 0x05000000,
    DOOR                           = 0x06000000,
    WHEEL                          = 0x07000000,
    BODY                           = 0x08000000,

    MASK                           = 0x0f000000,
};

/**
 * Various body in the car.
 */
enum VendorVehicleAreaBody : int32_t {
    BODY_FRONT                     = 0x0001,
    BODY_REAR                      = 0x0002,
    BODY_LEFT                      = 0x0004,
    BODY_RIGHT                     = 0x0008,
    BODY_FRONT_LEFT                = 0x0010,
    BODY_FRONT_MIDDLE_LEFT         = 0x0020,
    BODY_FRONT_MIDDLE_RIGHT        = 0x0040,
    BODY_FRONT_RIGHT               = 0x0080,
    BODY_REAR_LEFT                 = 0x0100,
    BODY_REAR_MIDDLE_LEFT          = 0x0200,
    BODY_REAR_MIDDLE_RIGHT         = 0x0400,
    BODY_REAR_RIGHT                = 0x0800,

};

/**
 * Various seat in the car.
 */
enum VendorVehicleAreaSeat : int32_t {
    SEAT_ROW_1_LEFT                = 0x0001,
    SEAT_ROW_1_CENTER              = 0x0002,
    SEAT_ROW_1_RIGHT               = 0x0004,
    SEAT_ROW_2_LEFT                = 0x0010,
    SEAT_ROW_2_CENTER              = 0x0020,
    SEAT_ROW_2_RIGHT               = 0x0040,
    SEAT_ROW_3_LEFT                = 0x0100,
    SEAT_ROW_3_CENTER              = 0x0200,
    SEAT_ROW_3_RIGHT               = 0x0400,

};

/**
 * Various mirror in the car.
 */
enum VendorVehicleAreaMirror : int32_t {
    MIRROR_DRIVER_LEFT             = 0x0001,
    MIRROR_DRIVER_RIGHT            = 0x0002,
    MIRROR_DRIVER_CENTER           = 0x0004,

};

/**
 * Various window in the car.
 */
enum VendorVehicleAreaWindow : int32_t {
    WINDOW_FRONT_WINDSHIELD        = 0x00000001,
    WINDOW_REAR_WINDSHIELD         = 0x00000002,
    WINDOW_ROW_1_LEFT              = 0x00000010,
    WINDOW_ROW_1_RIGHT             = 0x00000040,
    WINDOW_ROW_2_LEFT              = 0x00000100,
    WINDOW_ROW_2_RIGHT             = 0x00000400,
    WINDOW_ROW_3_LEFT              = 0x00001000,
    WINDOW_ROW_3_RIGHT             = 0x00004000,
    WINDOW_ROOF_TOP_1              = 0x00010000,
    WINDOW_ROOF_TOP_2              = 0x00020000,

};

/**
 * Various door in the car.
 */
enum VendorVehicleAreaDoor : int32_t {
    DOOR_ROW_1_LEFT                = 0x00000001,
    DOOR_ROW_1_RIGHT               = 0x00000004,
    DOOR_ROW_2_LEFT                = 0x00000010,
    DOOR_ROW_2_RIGHT               = 0x00000040,
    DOOR_ROW_3_LEFT                = 0x00000100,
    DOOR_ROW_3_RIGHT               = 0x00000400,
    DOOR_HOOD                      = 0x10000000,
    DOOR_REAR                      = 0x20000000,

};

/**
 * Various global in the car.
 */
enum VendorVehicleAreaGlobal : int32_t {
    GLOBAL                         = 0x0000,

};

/**
 * T1V vendor vehicle property
 */
enum VendorVehicleProperty : int32_t {
    VENDOR_PROPERTY_INVALID = 0x00000000,

    /**
     * ACU_3_CRASHOUTPUTSTS_21
     *
     * Function Describe: 碰撞状态信号
 Crash signal indicates the status according to bit:
 If multiple directions collide at the same time, each collision flag bit representing each direction will be set to 1.For example, if left crash is superimposed with right crash, the output signal is 00001100
 此信号发到ECU停止工作为止
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x0:No crash
         0x1:Belt Crash
         0x2:Front Crash
         0x4:Left Side Crash
         0x8:Right Side Crash
         0x10:Rear Crash
         0x20:Roll Crash
     */
    ACU_3_CRASHOUTPUTSTS_21 = (
        0x1002
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * BMS_PACKVOLTAGE_102
     *
     * Function Describe: 电池包电压（实际电压）
 Battery Voltage
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0xFFFE:Abnormal
         0xFFFF:Invalid
     */
    BMS_PACKVOLTAGE_102 = (
        0x100A
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * BMS_CHRGDCCNCTRDETD_102
     *
     * Function Describe: CC2连接状态
 CC2 connect state
 拆帧至DK 网段ID 0x4E9(FLZCU_28)14-15Bit
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x0:Init
         0x1:Connector not detected
         0x2:Connector detected
         0x3:SNS/Fault
     */
    BMS_CHRGDCCNCTRDETD_102 = (
        0x1021
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * BMS_DCCHGMODE_102
     *
     * Function Describe: 快充模式
 DC charge mode
 0x0:Default 默认值
 0x1:HandOver 握手
 0x2:ParaConfig充电配置
 0x3:Chging充电中
 0x4:ChgEnd充电结束
 0x5:ChgWaring充电警告
 0x6:ChgFault充电错误
 CATL无0x5状态，可以不进行配置。
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x0:Default
         0x1:HandOver
         0x2:ParaConfig
         0x3:Chging
         0x4:ChgEnd
         0x5:ChgWaring
         0x6:ChgFault
     */
    BMS_DCCHGMODE_102 = (
        0x1022
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * BMS_CHRGDCCHRGNFLTSTOPREAS_102
     *
     * Function Describe: Dc charge stop reason
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x0:no fault
         0x1:End by Infrastructure fault
         0x2:BMS fault
         0x3:CC2 fault
         0x4:DC charge not allowd because low temperature
         0x5:VCU fault
         0x6:Boost fault
         0x7:Other fault
     */
    BMS_CHRGDCCHRGNFLTSTOPREAS_102 = (
        0x1023
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * BMS_ISOLATIONFAULT_102
     *
     * Function Describe: 电池绝缘故障
 battery insulation fault state
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x0:no fault
         0x1:Fault L1
         0x2:Fault L2
         0x3:Fault L3
     */
    BMS_ISOLATIONFAULT_102 = (
        0x1030
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * BMS_SOCDIS_102
     *
     * Function Describe: 发送显示SOC
 battery indication SOC
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0x3FFE:Abnormal
         0x3FFF:Invalid
     */
    BMS_SOCDIS_102 = (
        0x1034
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
     * EMS_ENGINESPEED_ACTUAL_103
     *
     * Function Describe: 发动机转速（实际）
 PHEV:Actual Engine speed send by EMS to HCU
     * VehiclePropertyChangeMode:ON_CHANGE
     * VehiclePropertyAccess:READ
     * Signal Value:
        0xFFFF:Invalid
     */
    EMS_ENGINESPEED_ACTUAL_103 = (
        0x1036
        | VehiclePropertyGroup:VENDOR
        | VehiclePropertyType:INT32
        | VehicleArea:GLOBAL),

    /**
